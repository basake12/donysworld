generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  CLIENT
  MODEL
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BodyType {
  SLIM
  AVERAGE
  ATHLETIC
  CURVY
  PLUS_SIZE
}

enum Complexion {
  FAIR
  LIGHT
  MEDIUM
  OLIVE
  TAN
  DARK
}

enum MeetType {
  SHORT
  OVERNIGHT
  WEEKEND
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

enum TransactionType {
  FUND_WALLET
  OFFER_DEBIT
  OFFER_CREDIT
  FACE_REVEAL_DEBIT
  FACE_REVEAL_CREDIT
  CONNECTION_FEE
  REDEMPTION
  WITHDRAWAL
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ModelStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REJECTED
}

enum DocumentType {
  NIN
  DRIVERS_LICENSE
  VOTERS_CARD
  INTERNATIONAL_PASSPORT
}

enum FundingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BlocklistIdentifierType {
  EMAIL
  PHONE
  NAME
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  fullName       String
  nickname       String?
  email          String   @unique
  password       String
  role           Role
  gender         Gender
  whatsappNumber String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clientProfile    ClientProfile?
  modelProfile     ModelProfile?
  adminProfile     AdminProfile?
  wallet           Wallet?
  sentOffers       Offer[]              @relation("ClientOffers")
  receivedOffers   Offer[]              @relation("ModelOffers")
  notifications    Notification[]
  sessions         Session[]
  fundingRequests  FundingRequest[]
  modelBankAccounts ModelBankAccount[]
  withdrawalRequests WithdrawalRequest[]
  emailChangeTokens EmailChangeToken[]

  @@map("users")
}

// ─────────────────────────────────────────────
// AUTH SESSION
// ─────────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// PASSWORD RESET TOKEN
// ─────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// CLIENT PROFILE
// ─────────────────────────────────────────────

model ClientProfile {
  id                 String       @id @default(cuid())
  userId             String       @unique
  genderInterestedIn Gender
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  faceReveals        FaceReveal[]

  @@map("client_profiles")
}

// ─────────────────────────────────────────────
// MODEL PROFILE
// ─────────────────────────────────────────────

model ModelProfile {
  id                 String      @id @default(cuid())
  userId             String      @unique
  status             ModelStatus @default(PENDING_APPROVAL)
  age                Int
  height             String
  city               String
  state              String
  bodyType           BodyType
  complexion         Complexion
  about              String      @db.Text
  allowFaceReveal    Boolean     @default(false)
  profilePictureUrl  String      // blurred version — shown to all clients by default
  originalPictureUrl String?     // original — only returned to clients with an active reveal
  isFaceBlurred      Boolean     @default(true)
  isAvailable        Boolean     @default(true)

  gallery     ModelGallery[]
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   ModelDocument[]
  charges     ModelCharge[]
  faceReveals FaceReveal[]
  blocklist   ModelBlocklist[]

  @@map("model_profiles")
}

// ─────────────────────────────────────────────
// MODEL GALLERY
// ─────────────────────────────────────────────

model ModelGallery {
  id               String   @id @default(cuid())
  modelProfileId   String
  imageUrl         String   // blurred version — shown by default
  originalImageUrl String?  // original — only returned to clients with an active reveal
  order            Int      @default(0)
  createdAt        DateTime @default(now())

  modelProfile ModelProfile @relation(fields: [modelProfileId], references: [id], onDelete: Cascade)

  @@map("model_gallery")
}

// ─────────────────────────────────────────────
// MODEL DOCUMENT
// ─────────────────────────────────────────────

model ModelDocument {
  id             String       @id @default(cuid())
  modelProfileId String
  documentType   DocumentType
  documentUrl    String
  uploadedAt     DateTime     @default(now())

  modelProfile ModelProfile @relation(fields: [modelProfileId], references: [id], onDelete: Cascade)

  @@map("model_documents")
}

// ─────────────────────────────────────────────
// MODEL CHARGES
// ─────────────────────────────────────────────

model ModelCharge {
  id             String   @id @default(cuid())
  modelProfileId String
  meetType       MeetType
  minCoins       Int
  maxCoins       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  modelProfile ModelProfile @relation(fields: [modelProfileId], references: [id], onDelete: Cascade)

  @@unique([modelProfileId, meetType])
  @@map("model_charges")
}

// ─────────────────────────────────────────────
// MODEL BLOCKLIST
// ─────────────────────────────────────────────

model ModelBlocklist {
  id             String                  @id @default(cuid())
  modelProfileId String
  identifierType BlocklistIdentifierType
  identifier     String
  note           String?
  createdAt      DateTime                @default(now())

  modelProfile ModelProfile @relation(fields: [modelProfileId], references: [id], onDelete: Cascade)

  @@unique([modelProfileId, identifierType, identifier])
  @@index([modelProfileId])
  @@map("model_blocklist")
}

// ─────────────────────────────────────────────
// MODEL BANK ACCOUNT
// ─────────────────────────────────────────────

model ModelBankAccount {
  id            String   @id @default(cuid())
  modelUserId   String
  bankName      String
  accountNumber String
  accountName   String
  isPreferred   Boolean  @default(false)
  isLocked      Boolean  @default(true)
  createdAt     DateTime @default(now())

  user              User                @relation(fields: [modelUserId], references: [id], onDelete: Cascade)
  withdrawalRequests WithdrawalRequest[]

  @@map("model_bank_accounts")
}

// ─────────────────────────────────────────────
// WITHDRAWAL REQUEST
// ─────────────────────────────────────────────

model WithdrawalRequest {
  id            String           @id @default(cuid())
  modelUserId   String
  bankAccountId String
  coinsAmount   Int
  nairaAmount   Int
  status        WithdrawalStatus @default(PENDING)
  adminNote     String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())

  user        User             @relation(fields: [modelUserId], references: [id], onDelete: Cascade)
  bankAccount ModelBankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("withdrawal_requests")
}

// ─────────────────────────────────────────────
// ADMIN PROFILE
// ─────────────────────────────────────────────

model AdminProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

// ─────────────────────────────────────────────
// WALLET
// ─────────────────────────────────────────────

model Wallet {
  id           String        @id @default(cuid())
  userId       String        @unique
  balance      Int           @default(0)
  pendingCoins Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("wallets")
}

// ─────────────────────────────────────────────
// TRANSACTION
// ─────────────────────────────────────────────

model Transaction {
  id          String            @id @default(cuid())
  walletId    String
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Int
  description String
  reference   String?           @unique
  createdAt   DateTime          @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─────────────────────────────────────────────
// OFFER
// ─────────────────────────────────────────────

model Offer {
  id          String      @id @default(cuid())
  clientId    String
  modelId     String
  meetType    MeetType
  coinsAmount Int
  status      OfferStatus @default(PENDING)
  token       String?     @unique
  receipt     Receipt?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  client User @relation("ClientOffers", fields: [clientId], references: [id])
  model  User @relation("ModelOffers", fields: [modelId], references: [id])

  @@map("offers")
}

// ─────────────────────────────────────────────
// RECEIPT
// ─────────────────────────────────────────────

model Receipt {
  id            String    @id @default(cuid())
  offerId       String    @unique
  couponCode    String    @unique
  modelWhatsapp String
  coinsAmount   Int
  isRedeemed    Boolean   @default(false)
  redeemedAt    DateTime?
  createdAt     DateTime  @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("receipts")
}

// ─────────────────────────────────────────────
// FACE REVEAL
// ─────────────────────────────────────────────

model FaceReveal {
  id             String   @id @default(cuid())
  clientId       String
  modelProfileId String
  coinsCharged   Int      @default(1000)
  modelEarning   Int      @default(500)
  adminEarning   Int      @default(500)
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  client       ClientProfile @relation(fields: [clientId], references: [id])
  modelProfile ModelProfile  @relation(fields: [modelProfileId], references: [id])

  @@unique([clientId, modelProfileId])
  @@map("face_reveals")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─────────────────────────────────────────────
// BANK ACCOUNT
// ─────────────────────────────────────────────

model BankAccount {
  id            String   @id @default(cuid())
  bankName      String
  accountNumber String
  accountName   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("bank_accounts")
}

// ─────────────────────────────────────────────
// FUNDING REQUEST
// ─────────────────────────────────────────────

model FundingRequest {
  id            String               @id @default(cuid())
  userId        String
  nairaAmount   Int
  coinsAmount   Int
  proofImageUrl String
  status        FundingRequestStatus @default(PENDING)
  adminNote     String?
  reviewedAt    DateTime?
  createdAt     DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("funding_requests")
}

model EmailChangeToken {
  id        String   @id @default(cuid())
  userId    String
  newEmail  String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_change_tokens")
}